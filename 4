#include <stdio.h>
void Impares(int v[], int qtd);

int main() {
    int v[12];
    int i, qtd = 0;

  
    for(i = 0; i < 12; i++) {
        scanf("%d", &v[i]);
        qtd++; 
    }

    Impares(v, qtd);


    for(i = 0; i < qtd; i++) {
        printf("%d ", v[i]);
    }

    printf("\n");
    return 0;
}

void Impares(int v[], int qtd) {
    int i, j, tmp;

   
    for(i = 0; i < qtd - 1; i++) {
        for(j = 0; j < qtd - 1 - i; j++) {
         
            if(v[j] % 2 == 0) {
                tmp = v[j];
                v[j] = v[j + 1];
                v[j + 1] = tmp;
            }
        }
    }
}
